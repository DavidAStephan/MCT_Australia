# R session / project files
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj

# renv — keep lockfile and settings, ignore the library
renv/library/
renv/local/
renv/cellar/
renv/python/
renv/staging/

# Stan build artefacts
.cmdstan/
*.exe
stan/*.hpp
stan/*.o
# Compiled model binaries sit next to the .stan files (no extension on
# macOS/Linux). Add each variant explicitly — globbing "no-extension"
# files in a directory that also has .stan files is awkward in gitignore.
stan/mct_aus_A
stan/mct_aus_B
stan/mct_aus_C
stan/mct_aus_Ac
stan/mct_aus_Act
stan/mct_aus_Akf
stan/mct_aus_Akfs

# Cached data and posterior draws (huge; regenerable)
data/raw/*
!data/raw/.gitkeep
# Keep the weights workbook in-repo (small, rarely changes — ABS annual)
!data/raw/cpi_weights_*.xlsx
outputs/draws/*
!outputs/draws/.gitkeep
outputs/figures/*
!outputs/figures/.gitkeep
outputs/tables/*
!outputs/tables/.gitkeep
outputs/*.log

# Quarto build output
dashboard/_site/
dashboard/.quarto/
dashboard/*_files/

# targets store + per-machine config
_targets/
_targets.yaml
dashboard/_targets.yaml

# OS / editor cruft
.DS_Store
.vscode/
.idea/
